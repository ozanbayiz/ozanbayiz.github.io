{
    "name": "ozanbayiz.github.io",
    "homepage": "https://ozanbayiz.github.io",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --webpack",
        "build": "next build --webpack && next-image-export-optimizer",
        "analyze": "ANALYZE=true next build --webpack",
        "start": "pnpm dlx serve@latest out -l 3000",
        "preview": "pnpm dlx serve@latest out -l 3000",
        "lint": "oxlint --deny correctness",
        "lint:fix": "oxlint --deny correctness --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "typecheck": "tsc --noEmit",
        "predeploy": "pnpm run build",
        "deploy": "gh-pages -d out",
        "depcheck": "depcheck",
        "ts-prune": "ts-prune -p tsconfig.json"
    },
    "dependencies": {
        "@mdx-js/mdx": "^3.1.1",
        "clsx": "^2.1.1",
        "katex": "^0.17.0",
        "next": "^16.2.10",
        "next-image-export-optimizer": "^1.20.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^2.6.0",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@next/bundle-analyzer": "^16.2.10",
        "@types/mdx": "^2.0.14",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "depcheck": "^1.4.7",
        "eslint": "^9",
        "eslint-config-next": "^16.2.10",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-oxlint": "^1.49.0",
        "eslint-plugin-unused-imports": "^4.0.0",
        "gh-pages": "^6.3.0",
        "oxlint": "^1.49.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.10",
        "rehype-katex": "^7.0.1",
        "rehype-slug": "^6.0.0",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "tailwindcss": "^3.4.1",
        "ts-prune": "^0.10.3",
        "typescript": "^5"
    }
}
